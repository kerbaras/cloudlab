# cp route53-credentials.sops.yaml.example route53-credentials.sops.yaml
# → fill in the keys → sops -e -i route53-credentials.sops.yaml
# Applied by hand in README Stage 4 (sops -d ... | kubectl apply -f -);
# OpenBao / IRSA-style federation assumes custody of this in Phase 4.
#
# IAM policy for the user should be scoped to the zone:
#   route53:GetChange on arn:aws:route53:::change/*
#   route53:ChangeResourceRecordSets + ListResourceRecordSets on the
#   kerbaras.com hosted zone, route53:ListHostedZonesByName on *
apiVersion: v1
kind: Secret
metadata:
  name: route53-credentials
  namespace: cert-manager
type: Opaque
stringData:
  access-key-id: CHECKME
  secret-access-key: CHECKME
