# cp cloudflare-token.sops.yaml.example cloudflare-token.sops.yaml
# → fill in the token → sops -e -i cloudflare-token.sops.yaml
# Applied by hand in README Stage 4 (sops -d ... | kubectl apply -f -);
# OpenBao assumes custody of this in Phase 4.
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: cert-manager
type: Opaque
stringData:
  api-token: CHECKME # scoped token: Zone.DNS edit on the cloudlab.example zone
